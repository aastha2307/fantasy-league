// Reference schema (historical Prisma format). Runtime access uses `pg` + `DATABASE_URL`.
// Firebase Data Connect uses the *same* PostgreSQL database for GraphQL-defined tables (dataconnect/).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model League {
  id        String   @id @default(cuid())
  name      String
  joinCode  String   @unique
  createdAt DateTime @default(now())
  members   Member[]
  matches   Match[]
}

model Member {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  teams     TeamSubmission[]

  @@unique([leagueId, name])
}

model Match {
  id             String   @id @default(cuid())
  leagueId       String
  league         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  label          String
  matchDate      DateTime?
  /// Cricket Data / CricAPI match id for live scorecard (see https://www.cricapi.com/)
  cricApiMatchId String?
  createdAt      DateTime @default(now())
  points         PlayerMatchPoints[]
  teams          TeamSubmission[]
}

model TeamSubmission {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  imagePath   String?
  ocrText     String?
  playersJson String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([memberId, matchId])
}

model PlayerMatchPoints {
  id         String @id @default(cuid())
  matchId    String
  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerName String
  points     Float

  @@unique([matchId, playerName])
}

/// Public “join game” lobby for a live fixture (home page flow).
model GameRoom {
  id             String       @id @default(cuid())
  cricApiMatchId String       @unique
  label          String
  createdAt      DateTime     @default(now())
  participants   GamePlayer[]
}

model GamePlayer {
  id          String   @id @default(cuid())
  roomId      String
  room        GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  displayName String
  imagePath   String?
  ocrText     String?
  /// Dream11-style team total parsed from the screenshot (OCR).
  ocrPoints   Float?
  playersJson String
  createdAt   DateTime @default(now())

  @@unique([roomId, displayName])
}
