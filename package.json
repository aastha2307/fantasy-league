{
  "name": "ipl-fantasy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port ${PORT:-3000}",
    "dev:3001": "next dev --hostname 0.0.0.0 --port 3001",
    "kill:dev": "lsof -ti tcp:3000 | xargs kill 2>/dev/null || true",
    "build": "next build --webpack",
    "build:docker": "DOCKER_BUILD=1 next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "db:inspect": "node scripts/db-inspect.mjs",
    "dataconnect:sdk:generate": "firebase dataconnect:sdk:generate"
  },
  "dependencies": {
    "@ipl-fantasy/dataconnect": "file:src/lib/dataconnect-sdk",
    "cuid": "^3.0.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.0.2",
    "nanoid": "^5.1.9",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cuid": "^2.0.4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "enhanced-resolve": "^5.19.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "firebase-tools": "^13.29.1",
    "string-width": "^4.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
