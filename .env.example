# PostgreSQL (required). Local example matches docker compose service `db`:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iplfantasy"

# Public URL of this deployment (no trailing slash). Used for Open Graph / metadata in production.
# APP_URL=https://fantasy.example.com

# Optional: extra hostnames for Next.js HMR WebSockets when using a LAN IP (comma-separated, no http:)
# NEXT_DEV_ALLOWED_ORIGINS=10.0.0.15

# Free key: https://www.cricapi.com/signup.aspx — copy this file to .env and paste your key
CRICKET_API_KEY=

# Optional: Cricket Data series id for IPL match list on the home page (default is IPL 2026)
# IPL_SERIES_ID=87c62aac-bc3c-4738-ab93-19da0690488f
