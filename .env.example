# PostgreSQL (required).
#
# LOCAL (Docker): database name must be `iplfantasy` — not your Cloud SQL name.
# If DATABASE_URL ends with .../ipl-fantasy-league-71959-database on localhost, you will get
# "database does not exist". Use the line below for `docker compose up -d`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iplfantasy"
#
# Local DB: `docker compose up -d` then copy this file to `.env`.
# First-time schema: `psql "$DATABASE_URL" -f sql/init-schema.sql` (or recreate the volume).
# After creating a league/match in the app, run `npm run db:inspect` to see rows.
#
# PRODUCTION (Cloud SQL / App Hosting): use the secret URL from Firebase, e.g.
#   .../ipl-fantasy-league-71959-database?host=/cloudsql/...
# Never mix: localhost host + Cloud SQL database name — create `iplfantasy` locally or use the cloud URL only when the app runs in GCP.

# Public URL of this deployment (no trailing slash). Used for Open Graph / metadata in production.
# APP_URL=https://fantasy.example.com

# Optional: extra hostnames for Next.js HMR WebSockets when using a LAN IP (comma-separated, no http:)
# NEXT_DEV_ALLOWED_ORIGINS=10.0.0.15

# Free key: https://www.cricapi.com/signup.aspx — copy this file to .env and paste your key
CRICKET_API_KEY=

# Optional: Cricket Data series id for IPL match list on the home page (default is IPL 2026)
# IPL_SERIES_ID=87c62aac-bc3c-4738-ab93-19da0690488f

# Optional — Firebase Data Connect (server; defaults match dataconnect/dataconnect.yaml)
# DATA_CONNECT_SERVICE_ID=ipl-fantasy-league-71959-service
# DATA_CONNECT_LOCATION=asia-south1

# Firebase Web SDK (browser) — set in App Hosting for production builds (see apphosting.yaml)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ipl-fantasy-league-71959.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=ipl-fantasy-league-71959
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ipl-fantasy-league-71959.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=6454448286
# NEXT_PUBLIC_FIREBASE_APP_ID=1:6454448286:web:886fa7b0685880cb112b8f
